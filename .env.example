# ── LLM Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
XAI_API_KEY=xai-...
ELEVENLABS_API_KEY=...

# ── AWS S3 (CRM audio — read-only presigned URL access) ────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── App config ─────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=https://shinobi.prod.aleph-infinity.com

# ── Dev-only: push note artifacts back to CRM ─────────────────────────────────
# Enable only on development environment.
CRM_PUSH_ENABLED=false
CRM_PUSH_ENDPOINT=https://brtcrm.io/api/v1/accounts/{api_username}-incoming/
CRM_PUSH_API_USERNAME=
CRM_PUSH_API_PASSWORD=
CRM_PUSH_API_KEY=
CRM_PUSH_DATA_FIELD=note
CRM_PUSH_TIMEOUT_S=20

# ── GitHub (for deploy script to pull latest) ──────────────────────────────────
GITHUB_PAT=github_pat_...
